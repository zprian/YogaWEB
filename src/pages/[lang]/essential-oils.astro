---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { t, supportedLangs, type Lang } from '../../i18n/translations';

export function getStaticPaths() {
  return supportedLangs.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };

const oils = (await getCollection('oils'))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const oilsWithContent = await Promise.all(
  oils.map(async oil => {
    const { Content } = await oil.render();
    return { ...oil, Content };
  })
);
---

<Layout title={t(lang, 'nav.oils')} lang={lang}>

  <section class="page-hero">
    <h1>{t(lang, 'oils.title')}</h1>
    <p>{t(lang, 'oils.subtitle')}</p>
  </section>

  <div class="container">
    <div class="card intro-card">
      <h2>{t(lang, 'oils.intro_title')}</h2>
      <p>{t(lang, 'oils.intro_p1')}</p>
      <p>{t(lang, 'oils.intro_p2')}</p>
    </div>

    <!-- CAROUSEL -->
    <div class="carousel-wrap">
      <button class="carousel-btn prev" id="prevBtn" aria-label={t(lang, 'oils.prev')}>
        {t(lang, 'oils.prev')}
      </button>

      <div class="carousel" id="oilsCarousel">
        {oilsWithContent.map((oil, i) => (
          <div class="carousel-slide" data-index={i}>
            <div class="slide-inner card">
              <!-- Image -->
              <div class="slide-image-wrap">
                {oil.data.image
                  ? <img src={oil.data.image} alt={oil.data.title} class="slide-image" />
                  : <div class="slide-image-placeholder">🌿</div>
                }
              </div>

              <!-- Content -->
              <div class="slide-content">
                <h2 class="slide-title">{oil.data.title}</h2>
                <p class="slide-desc">{oil.data.description}</p>

                {oil.data.benefits && oil.data.benefits.length > 0 && (
                  <div class="slide-benefits">
                    <h3>{t(lang, 'oils.benefits')}</h3>
                    <ul>
                      {oil.data.benefits.map(b => <li>{b}</li>)}
                    </ul>
                  </div>
                )}

                <div class="slide-body">
                  <oil.Content />
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <button class="carousel-btn next" id="nextBtn" aria-label={t(lang, 'oils.next')}>
        {t(lang, 'oils.next')}
      </button>
    </div>

    <!-- Dots -->
    <div class="carousel-dots" id="carouselDots">
      {oilsWithContent.map((oil, i) => (
        <button class:list={['dot', { active: i === 0 }]} data-index={i} aria-label={oil.data.title}></button>
      ))}
    </div>

    <!-- Oil names nav -->
    <div class="oil-nav" id="oilNav">
      {oilsWithContent.map((oil, i) => (
        <button class:list={['oil-nav-btn', { active: i === 0 }]} data-index={i}>
          {oil.data.title}
        </button>
      ))}
    </div>

    <div class="card disclaimer">
      {t(lang, 'oils.disclaimer')}
    </div>
  </div>

</Layout>

<script>
  const carousel = document.getElementById('oilsCarousel') as HTMLElement;
  const slides = carousel.querySelectorAll('.carousel-slide');
  const dots = document.querySelectorAll('.dot');
  const navBtns = document.querySelectorAll('.oil-nav-btn');
  let current = 0;

  function goTo(index: number) {
    current = (index + slides.length) % slides.length;
    slides.forEach((s, i) => {
      (s as HTMLElement).style.display = i === current ? 'block' : 'none';
    });
    dots.forEach((d, i) => d.classList.toggle('active', i === current));
    navBtns.forEach((b, i) => b.classList.toggle('active', i === current));
  }

  // Init: hide all except first
  slides.forEach((s, i) => {
    (s as HTMLElement).style.display = i === 0 ? 'block' : 'none';
  });

  document.getElementById('prevBtn')?.addEventListener('click', () => goTo(current - 1));
  document.getElementById('nextBtn')?.addEventListener('click', () => goTo(current + 1));

  dots.forEach(d => d.addEventListener('click', () => goTo(Number((d as HTMLElement).dataset.index))));
  navBtns.forEach(b => b.addEventListener('click', () => goTo(Number((b as HTMLElement).dataset.index))));

  // Keyboard navigation
  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowLeft') goTo(current - 1);
    if (e.key === 'ArrowRight') goTo(current + 1);
  });
</script>

<style>
  .intro-card { margin-bottom: 2.5rem; }
  .intro-card h2 { font-size: 1.7rem; margin-bottom: 0.75rem; }
  .intro-card p { color: var(--text-muted); margin-bottom: 0.75rem; }

  /* CAROUSEL */
  .carousel-wrap {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .carousel { overflow: hidden; }

  .carousel-slide { display: none; }

  .slide-inner {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 0;
    padding: 0;
    overflow: hidden;
    min-height: 480px;
  }

  @media (max-width: 860px) {
    .slide-inner { grid-template-columns: 1fr; }
    .carousel-wrap { grid-template-columns: 1fr; }
    .carousel-btn { order: 0; width: 100%; }
  }

  .slide-image-wrap {
    position: relative;
    background: var(--green-pale);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .slide-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .slide-image-placeholder {
    font-size: 8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 380px;
    background: linear-gradient(135deg, var(--green-pale), #d4f0db);
  }

  .slide-content {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    overflow-y: auto;
  }

  .slide-title { font-size: 2rem; }
  .slide-desc { color: var(--text-muted); font-style: italic; font-size: 1.05rem; }

  .slide-benefits h3 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--brown);
    margin-bottom: 0.5rem;
  }

  .slide-benefits ul { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.3rem; }
  .slide-benefits li {
    font-size: 0.9rem;
    color: var(--text-muted);
    padding-left: 1.25rem;
    position: relative;
  }
  .slide-benefits li::before { content: '✓'; position: absolute; left: 0; color: var(--green); }

  .slide-body { font-size: 0.95rem; color: var(--text-muted); }
  .slide-body :global(p) { margin-bottom: 0.75rem; }
  .slide-body :global(strong) { color: var(--green); }

  /* BUTTONS */
  .carousel-btn {
    background: var(--green);
    color: var(--white);
    border: none;
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius);
    cursor: pointer;
    font-size: 0.95rem;
    white-space: nowrap;
    transition: background 0.2s;
    font-family: inherit;
  }

  .carousel-btn:hover { background: var(--green-light); }

  /* DOTS */
  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #ddd;
    border: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    padding: 0;
  }

  .dot.active { background: var(--green); transform: scale(1.3); }

  /* OIL NAME NAV */
  .oil-nav {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .oil-nav-btn {
    background: transparent;
    border: 1px solid #ddd;
    color: var(--text-muted);
    padding: 0.4rem 1rem;
    border-radius: 20px;
    cursor: pointer;
    font-size: 0.9rem;
    font-family: inherit;
    transition: all 0.2s;
  }

  .oil-nav-btn:hover { border-color: var(--green); color: var(--green); }
  .oil-nav-btn.active { background: var(--green); border-color: var(--green); color: var(--white); }

  /* DISCLAIMER */
  .disclaimer {
    background: var(--brown-light);
    border-left: 4px solid var(--brown);
    font-size: 0.9rem;
    color: var(--text-muted);
  }
</style>
