---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const latestNews = (await getCollection('news'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Layout title="Home" description="Welcome to our yoga studio — find balance, peace, and strength.">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <h1>Find Your Balance</h1>
      <p>A welcoming space for all levels — from your very first breath to your deepest practice.</p>
      <div class="hero-actions">
        <a href="/schedules" class="btn">View Schedules</a>
        <a href="/contact" class="btn btn-outline">Get in Touch</a>
      </div>
    </div>
  </section>

  <!-- ABOUT YOGA -->
  <section class="container">
    <div class="about-grid">
      <div class="about-text">
        <h2>What Is Yoga?</h2>
        <p>
          Yoga is an ancient practice originating in India over 5,000 years ago. The word "yoga" means
          <em>union</em> — a union of body, mind, and spirit. Through postures (asanas), breathwork
          (pranayama), and meditation, yoga offers a complete path to health and inner peace.
        </p>
        <p>
          Modern science confirms what yogis have known for millennia: regular practice reduces stress,
          improves flexibility and strength, supports heart health, and cultivates a profound sense of
          calm and presence.
        </p>
        <a href="/schedules" class="btn" style="margin-top:1rem">Start Your Journey</a>
      </div>
      <div class="about-cards">
        <div class="card benefit-card">
          <div class="benefit-icon">🧘</div>
          <h3>Mindfulness</h3>
          <p>Cultivate presence and stillness in every moment of daily life.</p>
        </div>
        <div class="card benefit-card">
          <div class="benefit-icon">💪</div>
          <h3>Strength</h3>
          <p>Build functional strength that supports you on and off the mat.</p>
        </div>
        <div class="card benefit-card">
          <div class="benefit-icon">🌿</div>
          <h3>Wellness</h3>
          <p>Support your whole health — body, mind, and spirit — through practice.</p>
        </div>
        <div class="card benefit-card">
          <div class="benefit-icon">🫁</div>
          <h3>Breathwork</h3>
          <p>Learn pranayama techniques to regulate your nervous system.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- LATEST NEWS -->
  {latestNews.length > 0 && (
    <section class="news-section">
      <div class="container">
        <h2>Latest News</h2>
        <div class="news-grid">
          {latestNews.map(post => (
            <a href={`/news/${post.slug}`} class="card news-card">
              <time>{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <span class="read-more">Read more →</span>
            </a>
          ))}
        </div>
        <div style="text-align:center; margin-top:2rem">
          <a href="/news" class="btn btn-outline">All News</a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="cta-section">
    <h2>Ready to Begin?</h2>
    <p>Your first class is waiting. Come as you are.</p>
    <a href="/contact" class="btn">Contact Us</a>
  </section>

</Layout>

<style>
  /* HERO */
  .hero {
    min-height: 85vh;
    background: linear-gradient(135deg, var(--green-pale) 0%, #d4eadb 50%, var(--brown-light) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 1.5rem;
  }

  .hero-content h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    margin-bottom: 1rem;
    color: var(--green);
  }

  .hero-content p {
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 560px;
    margin: 0 auto 2rem;
  }

  .hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  /* ABOUT */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (max-width: 760px) { .about-grid { grid-template-columns: 1fr; } }

  .about-text h2 { font-size: 2rem; margin-bottom: 1rem; }
  .about-text p { color: var(--text-muted); margin-bottom: 1rem; }

  .about-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .benefit-card { text-align: center; }
  .benefit-icon { font-size: 2rem; margin-bottom: 0.5rem; }
  .benefit-card h3 { font-size: 1.1rem; margin-bottom: 0.4rem; }
  .benefit-card p { font-size: 0.9rem; color: var(--text-muted); }

  /* NEWS */
  .news-section { background: var(--brown-light); padding: 1rem 0; }
  .news-section h2 { font-size: 2rem; margin-bottom: 2rem; }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .news-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: var(--text);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .news-card:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,0.12); text-decoration: none; }
  .news-card time { font-size: 0.85rem; color: var(--text-muted); }
  .news-card h3 { font-size: 1.15rem; color: var(--green); }
  .news-card p { font-size: 0.95rem; color: var(--text-muted); flex: 1; }
  .read-more { font-size: 0.9rem; color: var(--green); font-style: italic; }

  /* CTA */
  .cta-section {
    background: var(--green);
    color: var(--white);
    text-align: center;
    padding: 5rem 1.5rem;
  }

  .cta-section h2 { color: var(--white); font-size: 2.2rem; margin-bottom: 0.75rem; }
  .cta-section p { font-size: 1.15rem; margin-bottom: 2rem; opacity: 0.9; }
  .cta-section .btn { background: var(--white); color: var(--green); }
  .cta-section .btn:hover { background: var(--green-pale); }
</style>
