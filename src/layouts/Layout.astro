---
import { t, getLangFromUrl, getLocalizedPath, langNames, supportedLangs, type Lang } from '../i18n/translations';

export interface Props {
  title: string;
  description?: string;
  lang?: Lang;
}

const { title, description, lang: propLang } = Astro.props;
const lang: Lang = propLang ?? getLangFromUrl(Astro.url);
const desc = description ?? t(lang, 'hero.subtitle');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={desc} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Yoga Studio</title>
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body>
    <header>
      <nav>
        <a href={getLocalizedPath(lang, '/')} class="logo">🧘 Yoga Studio</a>
        <input type="checkbox" id="nav-toggle" class="nav-toggle" />
        <label for="nav-toggle" class="nav-burger" aria-label={t(lang, 'nav.menu')}>
          <span></span><span></span><span></span>
        </label>
        <ul class="nav-links">
          <li><a href={getLocalizedPath(lang, '/')}>{t(lang, 'nav.home')}</a></li>
          <li><a href={getLocalizedPath(lang, '/schedules')}>{t(lang, 'nav.schedules')}</a></li>
          <li><a href={getLocalizedPath(lang, '/news')}>{t(lang, 'nav.news')}</a></li>
          <li><a href={getLocalizedPath(lang, '/essential-oils')}>{t(lang, 'nav.oils')}</a></li>
          <li><a href={getLocalizedPath(lang, '/contact')}>{t(lang, 'nav.contact')}</a></li>
          <li class="lang-switcher">
            {supportedLangs.map(l => (
              <a
                href={getLocalizedPath(l, Astro.url.pathname)}
                class:list={['lang-btn', { active: l === lang }]}
                lang={l}
              >
                {langNames[l]}
              </a>
            ))}
          </li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>&copy; {new Date().getFullYear()} Yoga Studio. {t(lang, 'footer.rights')}</p>
      <p><a href={getLocalizedPath(lang, '/contact')}>{t(lang, 'footer.contact')}</a></p>
    </footer>

    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', (user: any) => {
          if (!user) {
            window.netlifyIdentity.on('login', () => {
              document.location.href = '/admin/';
            });
          }
        });
      }
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --green: #4a7c59;
    --green-light: #6aab80;
    --green-pale: #e8f5ec;
    --brown: #8b6f47;
    --brown-light: #f5efe6;
    --text: #2d2d2d;
    --text-muted: #666;
    --white: #ffffff;
    --radius: 8px;
    --shadow: 0 2px 12px rgba(0,0,0,0.08);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Georgia', serif;
    color: var(--text);
    background: var(--white);
    line-height: 1.7;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  main { flex: 1; }
  a { color: var(--green); text-decoration: none; }
  a:hover { text-decoration: underline; }
  h1, h2, h3 { font-family: 'Georgia', serif; color: var(--green); line-height: 1.3; }
  img { max-width: 100%; height: auto; }

  /* NAV */
  header {
    background: var(--white);
    border-bottom: 1px solid #e0e0e0;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: var(--shadow);
  }

  nav {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.85rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .logo { font-size: 1.2rem; font-weight: bold; color: var(--green); white-space: nowrap; }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 1.25rem;
    margin-left: auto;
    align-items: center;
    flex-wrap: wrap;
  }

  .nav-links a { color: var(--text); font-size: 0.9rem; transition: color 0.2s; }
  .nav-links a:hover { color: var(--green); text-decoration: none; }

  /* Language switcher */
  .lang-switcher {
    display: flex;
    gap: 0.25rem;
    border-left: 1px solid #ddd;
    padding-left: 1rem;
    margin-left: 0.25rem;
  }

  .lang-btn {
    font-size: 0.75rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    color: var(--text-muted) !important;
    border: 1px solid transparent;
    transition: all 0.2s;
  }

  .lang-btn:hover { border-color: var(--green); color: var(--green) !important; text-decoration: none; }
  .lang-btn.active { background: var(--green); color: var(--white) !important; border-color: var(--green); }

  .nav-toggle { display: none; }
  .nav-burger { display: none; cursor: pointer; flex-direction: column; gap: 5px; }
  .nav-burger span { display: block; width: 24px; height: 2px; background: var(--text); transition: 0.3s; }

  @media (max-width: 780px) {
    .nav-burger { display: flex; margin-left: auto; }
    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0; right: 0;
      background: var(--white);
      flex-direction: column;
      padding: 1rem 1.5rem;
      border-bottom: 1px solid #e0e0e0;
      gap: 0.75rem;
      align-items: flex-start;
    }
    .nav-toggle:checked ~ .nav-links { display: flex; }
    .lang-switcher { border-left: none; padding-left: 0; }
  }

  /* FOOTER */
  footer {
    background: var(--green);
    color: var(--white);
    text-align: center;
    padding: 2rem 1rem;
    font-size: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  footer a { color: var(--green-pale); }
  footer a:hover { color: var(--white); }

  /* SHARED */
  .page-hero {
    background: var(--green-pale);
    padding: 4rem 1.5rem;
    text-align: center;
  }

  .page-hero h1 { font-size: 2.5rem; margin-bottom: 0.75rem; }
  .page-hero p { color: var(--text-muted); font-size: 1.1rem; max-width: 600px; margin: 0 auto; }

  .container { max-width: 1200px; margin: 0 auto; padding: 3rem 1.5rem; }

  .card {
    background: var(--white);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.75rem;
    border: 1px solid #ece9e0;
  }

  .btn {
    display: inline-block;
    background: var(--green);
    color: var(--white);
    padding: 0.75rem 1.75rem;
    border-radius: var(--radius);
    font-size: 1rem;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
    text-decoration: none;
  }
  .btn:hover { background: var(--green-light); text-decoration: none; color: var(--white); }
  .btn-outline {
    background: transparent;
    border: 2px solid var(--green);
    color: var(--green);
  }
  .btn-outline:hover { background: var(--green); color: var(--white); }
</style>
